{
  "manifest_version": 3,
  "name": "Kairos",
  "version": "0.1.0",
  "description": "See what your mind is actually doing across your AI conversations.",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["src/content/interceptor.ts"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*"
      ],
      "js": ["src/content/bridge.ts"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/kairos-16.png",
      "48": "icons/kairos-48.png",
      "128": "icons/kairos-128.png"
    }
  },
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "https://*.vercel.app/*",
      "https://*.kairos.com/*"
    ]
  },
  "icons": {
    "16": "icons/kairos-16.png",
    "48": "icons/kairos-48.png",
    "128": "icons/kairos-128.png"
  }
}
