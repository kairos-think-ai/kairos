# Supabase (create a project at supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (for conversation analysis — get key at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key

# OpenAI (for message embeddings — get key at platform.openai.com)
OPENAI_API_KEY=sk-your-key

# Cron secret (any random string — protects admin endpoints)
CRON_SECRET=your-random-secret

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
